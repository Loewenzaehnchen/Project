            print("No country found")
            return

        print(f"Activity recommendations for {country}:")

        country_data = self.activity_database.get(country, {})

        if not country_data:
            print("No recommendations for selected country")
            return

        # Filter recommendations based on the traveler's chosen interests
        for activity_type in traveler.selected_activities: 

            activities = country_data.get(activity_type, [])

            if activities:
                print(f"\nFor interest in {activity_type.lower()} we recommend to:")
                for i, activity in enumerate(activities, 1):
                    print(f"    {i}. {activity}")

