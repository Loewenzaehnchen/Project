
import tkinter as tk
from tkinter import ttk
from tkinter import messagebox

root = tk.Tk()
root.title("Eco")
root.geometry("900x500")
root.configure(bg="gray")
var = tk.BooleanVar()

label = tk.Label(root, text="Hello! Welcome to the Start Screen", font=("Comic Sans", 30), anchor="se", fg="dark green", bg="gray")
label.pack(expand=True)

checkbox = tk.Checkbutton(root, text="Are you 18 or older?", variable=var, fg="dark green", bg="gray", anchor="center")
checkbox.deselect()
checkbox.config(state="normal")
checkbox.pack(padx=5, pady=10)

def on_click():
    label.config(text="Welcome to Ecotourism!")
def open_second():
    root.destroy()
    second_window()
def second_window():
    win = tk.Tk()
    win.geometry("900x500")
    win.configure(bg="gray")
    label = tk.Label(win, text="What are you interested in?", font=("Comic Sans", 30), anchor="se", fg="dark green", bg="gray")
    label.pack()

button = tk.Button(root, text="Click to Continue", command=open_second, fg="dark green", bg="gray")
button.pack(padx=5, pady=5)

# A helper label to show the result of the click
label = tk.Label(root, text="Click to Continue", fg="dark green", background="gray")
label.pack(padx=5, pady=5)

root.mainloop()
