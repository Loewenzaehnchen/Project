'''
Travel Recommendation System

Users input data about them, focusing on their interests 
selected from a given list. Answers correspond to a score 
that then corresponds to a Central American country

Tkinter is imported for final GUI

'''

import tkinter as tk
from tkinter import ttk, messagebox


class TravelerInput: 

    Available_Interests = {
    "more fauna",
    "more flora",
    "outdoors",
    "culture"
    }

    Interest_Scores = {
        "more flora": {
            "Savannah": 1,
            "Rainforest": 10
        },
        "more fauna": {
            "Marine Animals": 2,
            "Land Animals": 7,
            "Bird Watching": 12
        },
        "outdoors": {
            "Chill & Scenic": 3,
            "Long, Intense Hike": 16
        },
        "culture": {
            "Eat Local": 5,
            "Historical Sites": 14
        }
    }

    Countries_dictionary = [
        (0, 5, "Belize"),
        (6, 10, "El Salvador"),
        (11, 15, "Honduras"),
        (16, 20, "Nicaragua"),
        (21, 25, "Guatemala"),
        (26, 30, "Costa Rica"),
        (31, 35, "Panama")
    ]

    def __init__(self):
        self.age = None
        self.interests = []
        self.total_score = 0
        self.selected_activities = []

    def collect_age(self):
        self.root = tk.Tk()
        self.root.title("Travel Recommendation System")
        self.root.geometry("600x400")
        self.root.configure(bg="gray")

        # Age input
        self.age_var = tk.IntVar()
        age_label = tk.Label(self.root, text="Enter your age:", fg="dark green", bg="gray")
        age_entry = tk.Entry(self.root, textvariable=self.age_var)
        age_label.pack(pady=10)
        age_entry.pack(pady=10)

        continue_button = tk.Button(self.root, text="Continue", command=self.collect_interests, fg="dark green", bg="gray")
        continue_button.pack(pady=20)

        self.root.mainloop()

    def collect_interests(self):
        self.age = self.age_var.get()
        self.root.destroy()

        self.root = tk.Tk()
        self.root.title("Travel Recommendation System")
        self.root.geometry("600x400")
        self.root.configure(bg="gray")

        tk.Label(self.root, text="Select two interests:", font=("Comic Sans", 16), fg="dark green", bg="gray").pack(pady=20)

        self.interest_vars = [tk.BooleanVar() for _ in self.Available_Interests]
        for i, interest in enumerate(self.Available_Interests):
            cb = tk.Checkbutton(self.root, text=interest, variable=self.interest_vars[i], fg="dark green", bg="gray")
            cb.pack(pady=5)

        continue_button = tk.Button(self.root, text="Continue", command=self.collect_activities, fg="dark green", bg="gray")
        continue_button.pack(pady=20)

        self.root.mainloop()

    def collect_activities(self):
        self.interests = [interest for i, interest in enumerate(self.Available_Interests) if self.interest_vars[i].get()]
        self.root.destroy()

        self.root = tk.Tk()
        self.root.title("Travel Recommendation System")
        self.root.geometry("600x600")
        self.root.configure(bg="gray")

        for interest in self.interests:
            tk.Label(self.root, text=f"Based on your interest in {interest}:", font=("Comic Sans", 14), fg="dark green", bg="gray").pack(pady=10)

            options = list(self.Interest_Scores[interest].items())
            for activity, score in options:
                activity_var = tk.BooleanVar()
                activity_label = tk.Checkbutton(self.root, text=activity, variable=activity_var, fg="dark green", bg="gray")
                activity_label.pack(pady=5)

                activity_label.config(command=lambda var=activity_var, activity_name=activity, score=score: self.on_check(var, activity_name, score))

        submit_button = tk.Button(self.root, text="Submit", command=self.submit_selection, fg="dark green", bg="gray")
        submit_button.pack(pady=20)

        self.root.mainloop()

    def on_check(self, var, activity_name, score):
        if var.get():
            self.selected_activities.append(activity_name)
            self.total_score += score

    def submit_selection(self):
        TravellerOutput().display_result(self)

    def get_country(self):
        for lower_bound, upper_bound, country in self.Countries_dictionary:
            if lower_bound <= self.total_score <= upper_bound:
                return country
        return None

def on_check(var, activity_name, score):
    if var.get():
        self.selected_activities.append(activity_name)
        self.total_score += score
    def get_country(self):
        for lower_bound, upper_bound, country in self.Countries_dictionary:
            if lower_bound <= self.total_score <= upper_bound:
                return country
        return None

class TravellerOutput:
    def display_result(self, traveler):
        country = traveler.get_country()

        if country is None:
            messagebox.showerror("Error", "No country found based on your preferences.")
            return

        result_window = tk.Tk()
        result_window.title("Travel Recommendation")
        result_window.geometry("600x400")
        result_window.configure(bg="gray")

        result_label = tk.Label(result_window, text=f"Your travel recommendation is: {country.upper()}", font=("Comic Sans", 20), fg="dark green", bg="gray")
        result_label.pack(pady=50)

        activity_recommender = ActivityRecommender()
        activity_recommender.recommend(traveler, result_window)

        result_window.mainloop()

