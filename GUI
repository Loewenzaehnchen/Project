    def recommend(self, traveler, result_window):
        country = traveler.get_country()

        if country is None:
            return

        country_data = self.activity_database.get(country, {})

        if not country_data:
            return

        for activity_type in traveler.selected_activities:
            activities = country_data.get(activity_type, [])

            if activities:
                activity_label = tk.Label(result_window, text=f"For interest in {activity_type.lower()}, we recommend:", font=("Comic Sans", 16), fg="dark green", bg="gray")
                activity_label.pack(pady=20)

                for i, activity in enumerate(activities, 1):
                    activity_text = tk.Label(result_window, text=f"{i}. {activity}", fg="dark green", bg="gray")
                    activity_text.pack(pady=5)

        result_window.mainloop()  # You might want to place this outside the loop

