    def recommend(self, traveler, result_window):
        country = traveler.get_country()
        country_data = self.activity_database.get(country, {})

        if not country_data:
            return

        recommendation_frame = tk.Frame(result_window, bg="white")
        recommendation_frame.pack(pady=10)

        tk.Label(
            recommendation_frame,
            text="Recommended Activities:",
            font=("Helvetica", 20, "bold"),
            fg="dark green",
            bg="white"
        ).pack(pady=10)

        for activity_type, score in traveler.selected_activities:
            activities = country_data.get(activity_type, [])
            if activities:
                tk.Label(
                    recommendation_frame,
                    text=f"For interest in {activity_type.lower()} we recommend to:",
                    font=("Helvetica", 14, "bold"),
                    fg="dark green",
                    bg="white"
                ).pack()

                for activity in activities:
                    tk.Label(
                        recommendation_frame,
                        text=f"• {activity}",
                        fg="dark green",
                        bg="white",
                        font=("Helvetica", 12)
                    ).pack()
