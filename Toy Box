        self.interests = []
        
    
    def collect_user_input(self):
        print("Available interests:")
        for interest in self.Available_Interests:
            print("-", interest)
        while True:
            try:
                age = int(input("Enter your age: "))
                if age < 18:
                    print("You too young")
                    continue
                self.age = age
                break
            except ValueError:
                print("Please enter a valid number.")
        while True:
            interest1 = input("Choose first interest: ")
            interest2 = input("Choose second interest: ")

